---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="group relative bg-white p-7 border border-border-default hover:border-primary/30 transition-all duration-200">
  <div class="w-12 h-12 bg-primary/8 flex items-center justify-center mb-4 group-hover:bg-primary/15 transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-base font-bold text-ink mb-2" style="font-family: var(--font-heading);">{title}</h3>
  <p class="text-ink-muted text-sm leading-relaxed">{description}</p>
</div>
