---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref = '/contact',
  secondaryCtaText,
  secondaryCtaHref,
  compact = false,
} = Astro.props;
---

<section class:list={[
  'relative overflow-hidden',
  compact ? 'py-16 lg:py-24' : 'py-24 lg:py-36',
]} style="background: linear-gradient(135deg, #006F51 0%, #005a42 40%, #1E3A5F 100%);">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="1.5" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-pattern)"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
    <h1 class:list={[
      'text-display font-extrabold text-white leading-tight',
      compact ? 'text-3xl sm:text-4xl lg:text-5xl' : '',
    ]}>
      {title}
    </h1>
    <p class:list={[
      'mt-6 text-white/85 max-w-2xl leading-relaxed',
      compact ? 'text-lg' : 'text-lg sm:text-xl',
    ]}>
      {subtitle}
    </p>
    {(ctaText || secondaryCtaText) && (
      <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
        {ctaText && (
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 bg-white text-primary px-8 py-4 rounded-lg text-base font-semibold hover:bg-gray-100 transition-colors shadow-lg shadow-black/10"
          >
            {ctaText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        )}
        {secondaryCtaText && (
          <a
            href={secondaryCtaHref}
            class="inline-flex items-center gap-2 border-2 border-white/30 text-white px-8 py-4 rounded-lg text-base font-semibold hover:bg-white/10 transition-colors"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
    )}
    </div>
  </div>
</section>
