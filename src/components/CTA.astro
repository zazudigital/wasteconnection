---
interface Props {
  variant?: 'app' | 'contact';
}

const { variant = 'app' } = Astro.props;
---

{variant === 'app' ? (
  <section class="py-20 lg:py-28" style="background: linear-gradient(135deg, #006F51 0%, #1E3A5F 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 text-white/90 text-sm font-medium px-4 py-2 rounded-none mb-6">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/>
          </svg>
          Available on iOS & Android
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-6">
          Your Waste Services, in Your Pocket
        </h2>
        <p class="text-lg text-white/80 mb-10 leading-relaxed">
          The WasteConnect&trade; app puts you in control. Check your next pickup day, get real-time collection alerts, browse disposal guides for tricky items, pay your bill securely, and report a missed pickup in under 30 seconds &mdash; no phone call needed.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="inline-flex items-center gap-3 bg-white text-gray-900 pl-5 pr-7 py-3.5 rounded-none font-semibold hover:bg-gray-100 transition-colors"
          >
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            <div class="text-left">
              <div class="text-xs text-gray-500">Download on the</div>
              <div class="text-base font-bold -mt-0.5">App Store</div>
            </div>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-3 bg-white text-gray-900 pl-5 pr-7 py-3.5 rounded-none font-semibold hover:bg-gray-100 transition-colors"
          >
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.2l2.807 1.626a1 1 0 0 1 0 1.734l-2.807 1.626L15.206 12l2.492-2.493zM5.864 3.387L16.8 9.72l-2.302 2.302-8.634-8.635z"/>
            </svg>
            <div class="text-left">
              <div class="text-xs text-gray-500">Get it on</div>
              <div class="text-base font-bold -mt-0.5">Google Play</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="py-20 lg:py-28 bg-surface-dim">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="border-l-4 border-primary pl-8 lg:pl-12 max-w-3xl">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-ink mb-4">
          Let Us Handle the Waste &mdash; You Focus on What Matters
        </h2>
        <p class="text-lg text-ink-muted mb-8">
          Whether you need curbside pickup for your home or a full waste management plan for your business, our team will build a solution tailored to your needs. Get a free quote or speak with a local service representative today.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-none font-semibold hover:bg-primary-dark transition-colors"
          >
            Contact Us
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="tel:8447087274"
            class="inline-flex items-center gap-2 border-2 border-primary text-primary px-8 py-4 rounded-none font-semibold hover:bg-primary hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Call 844-708-7274
          </a>
        </div>
      </div>
    </div>
  </section>
)}
