---
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const quickLinks = [
  { href: localePath(locale, '/'), label: t('nav.home') },
  { href: localePath(locale, '/diensten'), label: t('nav.diensten') },
  { href: localePath(locale, '/over-ons'), label: t('nav.overOns') },
  { href: localePath(locale, '/contact'), label: t('nav.contact') },
];

const serviceLinks = [
  { href: localePath(locale, '/diensten#afvalhout'), label: 'Afvalhout' },
  { href: localePath(locale, '/diensten#banden'), label: 'Banden' },
  { href: localePath(locale, '/diensten#bedrijfsafval'), label: 'Bedrijfsafval' },
  { href: localePath(locale, '/diensten#papier'), label: 'Papier' },
];

const year = new Date().getFullYear();
---

<!-- Dark green watermark band -->
<div class="bg-primary-dark relative overflow-hidden py-8" aria-hidden="true">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <span class="text-white/[0.06] font-extrabold whitespace-nowrap select-none pointer-events-none" style="font-size: clamp(4rem, 10vw, 8rem); font-family: var(--font-heading); line-height: 1;">WasteConnection</span>
  </div>
</div>

<footer class="bg-secondary text-white border-t-[3px] border-t-primary">
  <!-- Trust line -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center gap-3">
      <div class="w-1.5 h-1.5 bg-primary rounded-full shrink-0"></div>
      <p class="text-sm text-gray-300 font-medium" style="font-family: var(--font-heading);">{t('footer.trustLine')}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href={localePath(locale, '/')} class="flex items-center gap-3 mb-4 logo-hover">
          <div class="w-12 h-12 bg-primary flex items-center justify-center logo-icon transition-all duration-250">
            <span class="text-white font-extrabold text-base" style="font-family: var(--font-heading);">WC</span>
          </div>
          <span class="text-2xl font-extrabold" style="font-family: var(--font-heading);">WasteConnection</span>
        </a>
        <p class="text-gray-300 text-sm leading-relaxed mb-6">
          {t('footer.brandDescription')}
        </p>
        <div class="flex items-start gap-2 text-gray-400 text-sm mb-4">
          <svg class="w-4 h-4 text-primary mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <span>Nieuwe Bredase Baan 30, 4825 BP Breda</span>
        </div>
        <a
          href="tel:+31411611470"
          class="inline-flex items-center gap-2 text-white font-semibold hover:text-accent-light transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          +31(0)411-611470
        </a>
      </div>

      <!-- Quick Links -->
      <div class="footer-link-group">
        <h3 class="label text-gray-300 mb-4">{t('footer.quickLinks')}</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-link-group">
        <h3 class="label text-gray-300 mb-4">{t('footer.ourServices')}</h3>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6 border-t border-white/10 pt-5">
          <h3 class="label text-gray-300 mb-2">{t('footer.charity')}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{t('footer.charityText')} <span class="text-gray-300 font-medium">{t('footer.charityOrg')}</span> <svg class="inline w-3.5 h-3.5 text-red-400 -mt-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg> {t('footer.charityDescription')}</p>
        </div>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="label text-gray-300 mb-4">{t('footer.contactHeading')}</h3>
        <ul class="space-y-4 text-sm text-gray-400">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <div>
              <span class="block text-white font-medium">{t('footer.phone')}</span>
              <a href="tel:+31411611470" class="hover:text-white transition-colors">+31(0)411-611470</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <div>
              <span class="block text-white font-medium">{t('footer.email')}</span>
              <a href="mailto:Info@WasteConnection.nl" class="hover:text-white transition-colors">Info@WasteConnection.nl</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <div>
              <span class="block text-white font-medium">{t('footer.address')}</span>
              <span>Nieuwe Bredase Baan 30<br/>4825 BP Breda</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-px bg-primary/40"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-6">
        <p class="text-gray-400 text-sm">
          &copy; {year} WasteConnection. {t('footer.copyright')}
        </p>
        <span class="hidden sm:inline text-white/20">|</span>
        <span class="inline-flex items-center gap-1.5 text-xs text-gray-500 font-medium uppercase tracking-wider border border-white/10 px-2.5 py-1 rounded-sm">
          <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
          {t('footer.niwoCertified')}
        </span>
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-400">
        <a href="#" class="hover:text-white transition-colors hover:underline underline-offset-4 decoration-transparent hover:decoration-current">{t('footer.privacy')}</a>
        <a href="#" class="hover:text-white transition-colors hover:underline underline-offset-4 decoration-transparent hover:decoration-current">{t('footer.terms')}</a>
      </div>
    </div>
  </div>
</footer>
