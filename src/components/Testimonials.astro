---
import { useTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const approaches = t('testimonials.approaches') as Array<{ name: string; role: string; quote: string }>;
---

<section class="py-20 lg:py-28 bg-surface-bright">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <span class="label">{t('testimonials.label')}</span>
      <h2 class="mt-3 text-h2 font-extrabold text-ink">
        {t('testimonials.heading')}
      </h2>
    </div>

    <!-- Featured approach — dramatic, full-width -->
    <div class="relative border-l-4 border-primary pl-8 lg:pl-12 mb-16">
      <!-- Massive quotation mark -->
      <div class="absolute -top-8 -left-2 text-primary/12 select-none pointer-events-none" aria-hidden="true" style="font-size: 14rem; font-family: Georgia, 'Times New Roman', serif; line-height: 1;">&ldquo;</div>
      <blockquote class="relative text-xl sm:text-2xl lg:text-3xl text-ink leading-snug font-medium max-w-4xl" style="font-family: Georgia, 'Times New Roman', serif;">
        {approaches[0].quote}
      </blockquote>
      <div class="mt-8 flex items-center gap-4">
        <div class="w-10 h-10 bg-primary rounded-md flex items-center justify-center">
          <span class="text-white font-bold text-sm" style="font-family: var(--font-heading);">WC</span>
        </div>
        <div>
          <div class="font-bold text-ink text-sm" style="font-family: var(--font-heading);">{approaches[0].name}</div>
          <div class="text-ink-subtle text-xs">{approaches[0].role}</div>
        </div>
      </div>
    </div>

    <!-- Two smaller quotes side by side -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {[approaches[1], approaches[2]].map((item) => (
        <div class="approach-card border border-border-default p-6 lg:p-8 cursor-default">
          <blockquote class="text-ink-muted text-sm leading-relaxed mb-5" style="font-family: Georgia, 'Times New Roman', serif;">
            &ldquo;{item.quote}&rdquo;
          </blockquote>
          <div class="flex items-center gap-3 border-t border-border-subtle pt-4">
            <div class="w-8 h-8 bg-primary/10 rounded-md flex items-center justify-center">
              <span class="text-primary font-bold text-xs" style="font-family: var(--font-heading);">WC</span>
            </div>
            <div>
              <div class="font-bold text-ink text-sm" style="font-family: var(--font-heading);">{item.name}</div>
              <div class="text-ink-subtle text-xs">{item.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
