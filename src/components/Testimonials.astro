---
const approaches = [
  {
    name: 'Het Uitruil-principe',
    role: 'Kern van ons collectief',
    quote: 'Door slim vraag en aanbod te matchen tussen onze 40+ deelnemers, optimaliseren wij de logistiek en drukken we de kosten. Dit uitruil-principe zorgt ervoor dat elke deelnemer profiteert van schaalvoordelen die individueel onbereikbaar zouden zijn. Zo creeren wij samen meer waarde uit elke afvalstroom.',
  },
  {
    name: 'Transparantie',
    role: 'Onze belofte aan deelnemers',
    quote: 'Wij geloven dat transparantie in afvalverwerking fundamenteel is. Elke deelnemer weet precies waar zijn afval naartoe gaat, hoe het verwerkt wordt en welke tarieven daarbij horen. Geen verborgen kosten, geen onduidelijkheid.',
  },
  {
    name: 'Langetermijncontracten',
    role: 'Stabiliteit voor deelnemers',
    quote: 'Met contracten van 1 tot 17 jaar bij grote energieproducenten zoals Essent en RWE bieden wij onze deelnemers prijsstabiliteit en zekerheid. Zo worden bedrijven ontzorgd en kunnen zij zich richten op hun eigen kernactiviteiten.',
  },
];
---

<section class="py-16 lg:py-24 bg-surface-bright">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-14">
      <span class="label">Onze Aanpak</span>
      <h2 class="mt-3 text-h2 font-extrabold text-ink">
        Samen sterker door collectieve kracht
      </h2>
    </div>

    <!-- Featured approach — dramatic, full-width -->
    <div class="relative border-l-4 border-primary pl-8 lg:pl-12 mb-14">
      <!-- Massive quotation mark -->
      <div class="absolute -top-4 -left-1 text-primary/15 select-none pointer-events-none" aria-hidden="true" style="font-size: 10rem; font-family: Georgia, 'Times New Roman', serif; line-height: 1;">&ldquo;</div>
      <blockquote class="relative text-xl sm:text-2xl lg:text-3xl text-ink leading-snug font-medium max-w-4xl" style="font-family: Georgia, 'Times New Roman', serif;">
        {approaches[0].quote}
      </blockquote>
      <div class="mt-8 flex items-center gap-4">
        <div class="w-10 h-10 bg-primary rounded-md flex items-center justify-center">
          <span class="text-white font-bold text-sm" style="font-family: var(--font-heading);">WC</span>
        </div>
        <div>
          <div class="font-bold text-ink text-sm" style="font-family: var(--font-heading);">{approaches[0].name}</div>
          <div class="text-ink-subtle text-xs">{approaches[0].role}</div>
        </div>
      </div>
    </div>

    <!-- Two smaller quotes side by side -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {[approaches[1], approaches[2]].map((t) => (
        <div class="border border-border-default p-6 lg:p-8">
          <blockquote class="text-ink-muted text-sm leading-relaxed mb-5" style="font-family: Georgia, 'Times New Roman', serif;">
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <div class="flex items-center gap-3 border-t border-border-subtle pt-4">
            <div class="w-8 h-8 bg-primary/10 rounded-md flex items-center justify-center">
              <span class="text-primary font-bold text-xs" style="font-family: var(--font-heading);">WC</span>
            </div>
            <div>
              <div class="font-bold text-ink text-sm" style="font-family: var(--font-heading);">{t.name}</div>
              <div class="text-ink-subtle text-xs">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
