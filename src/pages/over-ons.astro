---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import CTA from '../components/CTA.astro';

const values = [
  {
    title: 'Schaalvoordelen door het Collectief',
    description: 'De kern van WasteConnection is het collectief. Door de volumes van een groot aantal recyclingbedrijven te bundelen creeren wij schaalvoordelen die individueel onbereikbaar zijn. Van sloophout voor de RWE biomassacentrale tot banden voor cementovens &mdash; samen realiseren wij betere tarieven.',
  },
  {
    title: 'Volledige Ontzorging',
    description: 'Door de ontzorging hoeft het recyclingbedrijf zich alleen nog maar bezig te houden met hun kerntaken en klanten. Wij verzorgen exportvergunningen, kwaliteitsborging, transportplanning, administratie en financiele afwikkeling &mdash; het complete traject van bron tot verwerker.',
  },
  {
    title: 'Sterke Partnerschappen',
    description: 'Langetermijncontracten van 1 tot 17 jaar met grote energieproducenten als Essent en RWE. Samenwerking met Smurfit Kappa Recycling voor papier. En onze zusteronderneming Milieu Service Brabant voor inzameling en logistiek. Een sterk netwerk dat zekerheid en stabiliteit biedt.',
  },
  {
    title: 'Duurzaam Ondernemen',
    description: 'Nederlandse AVIs beschikken over de R1-status voor superieure energieterugwinning. Hout wordt verwerkt tot biomassa en spaanplaat. Banden worden secundaire brandstof voor cementovens. Deelname aan het collectief versterkt de duurzaamheidspositionering van uw bedrijf.',
  },
];

const timeline = [
  { year: 'Begin 2000', event: 'WasteConnection start met de verwerking van sloop- en afvalhout in samenwerking met de RWE biomassacentrale in Duitsland. Dit partnerschap legt de basis voor het collectief en de ontzorging die wij vandaag bieden.' },
  { year: 'Groei', event: 'Een groeiend aantal recyclingbedrijven sluit zich aan als partner. Het dienstenpakket wordt uitgebreid met bandenverwerking, bedrijfsafval en papierrecycling. Langetermijncontracten van 1 tot 17 jaar met Essent en RWE bieden prijsstabiliteit.' },
  { year: '2013', event: 'Onze zusteronderneming Milieu Service Brabant neemt de papierinzameling in Eindhoven over van Smurfit Kappa. Dit versterkt ons netwerk en onze expertise in papierrecycling aanzienlijk.' },
  { year: 'Partnerschappen', event: 'Samenwerking met Smurfit Kappa Recycling voor marktconforme papierafzet. Contracten met grote energieproducenten voor bedrijfsafval met R1-verwerking. Bandenverwerking voor cementovens. Een compleet netwerk van betrouwbare partners.' },
  { year: 'Vandaag', event: 'Een groot aantal recyclingbedrijven profiteert van de schaalvoordelen en ontzorging van WasteConnection. Vanuit Breda verzorgen wij het complete traject: exportvergunningen, kwaliteitsborging, transportplanning en financiele afwikkeling.' },
];
---

<Layout title="Over Ons" description="WasteConnection is het afvalcollectief in Breda dat sinds 2005 bedrijven sterker maakt. Meer dan 40 deelnemende bedrijven profiteren van collectieve inkoop, transparante processen en NIWO-gecertificeerde dienstverlening.">
  <Hero
    title="Het collectief dat bedrijven sterker maakt"
    subtitle="Al sinds begin 2000 ontzorgt WasteConnection recyclingbedrijven op het gebied van afvalverwerking. Samen met partners als RWE, Smurfit Kappa en zusteronderneming Milieu Service Brabant realiseren wij schaalvoordelen door collectieve kracht."
    compact
  />

  <!-- Mission Section -->
  <section class="py-20 lg:py-28 bg-surface-bright" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Onze Missie</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Bedrijven ontzorgen door collectieve kracht
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            WasteConnection is een collectief dat recyclingbedrijven en andere ondernemingen volledig ontzorgt op het gebied van afvalverwerking. Wij zijn geen traditioneel afvalbedrijf &mdash; wij zijn een samenwerkingsverband dat de krachten bundelt om schaalvoordelen te realiseren die individueel onbereikbaar zijn.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Onze missie is helder: ontzorging door collectieve kracht. Al sinds begin 2000 werken wij samen met de RWE biomassacentrale in Duitsland voor afvalhout, en met Smurfit Kappa Recycling voor papier. Door de volumes te bundelen en langetermijncontracten af te sluiten met grote energieproducenten als Essent en RWE bieden wij prijsstabiliteit, zekerheid en duurzaamheidsvoordelen.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed">
            Samen met onze zusteronderneming Milieu Service Brabant &mdash; die in 2013 de papierinzameling in Eindhoven overnam van Smurfit Kappa &mdash; vormen wij een sterk netwerk. Gevestigd aan de Nieuwe Bredase Baan 30 in Breda zijn wij een centraal aanspreekpunt voor duurzame afvaloplossingen.
          </p>
        </div>
        <div class="relative">
          <img src="/images/recycling.jpg" alt="Duurzame afvalverwerking door het collectief" loading="lazy" width="800" height="600" class="w-full h-56 object-cover rounded-sm mb-6" />
          <div class="overflow-hidden border-l-4 border-primary" style="background: linear-gradient(135deg, #85a71e 0%, #2d3a1a 100%);">
            <div class="p-10 lg:p-14">
              <blockquote class="text-white text-xl lg:text-2xl font-medium leading-relaxed mb-6" style="font-family: Georgia, 'Times New Roman', serif;">
                &ldquo;Door de ontzorging hoeft het recyclingbedrijf zich alleen nog maar bezig te houden met hun kerntaken en klanten. Profiteer van de schaalvoordelen van ons collectief.&rdquo;
              </blockquote>
              <div class="flex items-center gap-3">
                <div class="w-1 h-12 bg-accent"></div>
                <div>
                  <div class="text-white font-semibold">WasteConnection</div>
                  <div class="text-white/70 text-sm">Het Collectief in Breda</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-white" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">Onze Waarden</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          De principes achter ons collectief
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-2xl mx-auto">
          Deze waarden vormen het fundament van alles wat wij doen &mdash; van de manier waarop wij onderhandelen met verwerkers tot de transparantie die wij bieden aan elke deelnemer.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-border-default">
        {values.map((value, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < 2 ? 'border-b border-border-default' : '',
            i % 2 === 0 ? 'md:border-r border-border-default' : '',
          ]}>
            <span class="text-3xl font-extrabold text-primary/25 block mb-3" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">{value.title}</h3>
            <p class="text-ink-muted leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Stats />

  <!-- Timeline -->
  <section class="py-20 lg:py-28 bg-surface-bright" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">Onze Geschiedenis</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Van partnerschap tot collectief
        </h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-4 top-0 bottom-0 w-px bg-border-default"></div>

          <div class="space-y-10">
            {timeline.map((item) => (
              <div class="relative flex items-start gap-6 pl-0">
                <div class="relative z-10 w-8 h-8 bg-primary flex items-center justify-center shrink-0">
                  <div class="w-2 h-2 bg-white"></div>
                </div>
                <div class="pt-0.5">
                  <div class="text-primary font-bold text-lg mb-1" style="font-family: var(--font-heading);">{item.year}</div>
                  <p class="text-ink-muted leading-relaxed">{item.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Charity & Sustainability -->
  <section class="py-20 lg:py-28 bg-white" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Maatschappelijke Betrokkenheid</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Meer dan afval &mdash; maatschappelijke impact
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            WasteConnection gelooft dat ondernemen verder gaat dan winst maken. Samen met onze zusteronderneming Milieu Service Brabant en zusterorganisatie Ecopark Breda zetten wij ons actief in voor maatschappelijke doelen en duurzame ontwikkeling. Wij steunen Stichting Prithipura, een goed doel dat zich inzet voor kwetsbare mensen.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 border border-border-default">
            <div class="p-6 border-b border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Stichting Prithipura</div>
              <p class="text-ink-muted text-sm">Wij steunen Stichting Prithipura die zich inzet voor kwetsbare mensen. Een deel van onze collectieve opbrengsten wordt jaarlijks gedoneerd aan dit goede doel.</p>
            </div>
            <div class="p-6 border-b border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Circulaire Economie</div>
              <p class="text-ink-muted text-sm">Door afvalstromen verantwoord te verwerken en te recyclen dragen wij bij aan een circulaire economie. Afval wordt grondstof, niet eindproduct.</p>
            </div>
            <div class="p-6 border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">NIWO Certificering</div>
              <p class="text-ink-muted text-sm">Onze NIWO-certificering bevestigt dat wij voldoen aan de hoogste normen voor beroepsgoederenvervoer en afvaltransport in Nederland.</p>
            </div>
            <div class="p-6">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Milieu Service Brabant</div>
              <p class="text-ink-muted text-sm">Onze zusteronderneming Milieu Service Brabant versterkt ons netwerk met expertise in inzameling en logistiek. In 2013 nam zij de papierinzameling in Eindhoven over van Smurfit Kappa.</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/images/sustainability.jpg" alt="Duurzaam ondernemen bij WasteConnection" loading="lazy" width="800" height="600" class="w-full h-64 object-cover mb-6 rounded-sm" />
          <div class="border border-border-default p-8 lg:p-12 text-center bg-surface-dim">
            <div class="w-24 h-24 bg-primary/10 flex items-center justify-center mx-auto mb-6">
              <svg class="w-12 h-12 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">Een prima vraagbaak</h3>
            <p class="text-ink-muted leading-relaxed max-w-md mx-auto">
              WasteConnection is meer dan een dienstverlener &mdash; wij zijn een kennispartner. Voor al uw vragen over afvalverwerking, wet- en regelgeving en duurzame oplossingen kunt u bij ons terecht. Ons collectief deelt kennis, ervaring en expertise.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
