---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
---

<Layout title="Contact" description="Neem contact op met WasteConnection voor vrijblijvend advies over collectieve afvalverwerking. Bel +31(0)411-611470 of mail naar Info@WasteConnection.nl.">
  <Hero
    title="Neem contact met ons op"
    subtitle="Benieuwd naar de voordelen van collectieve afvalverwerking? Wij adviseren u graag vrijblijvend over de mogelijkheden en besparingen voor uw bedrijf."
    compact
  />

  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-ink mb-2" style="font-family: var(--font-heading);">Stuur ons een bericht</h2>
          <p class="text-ink-muted mb-8">Vertel ons wat u nodig heeft en wij nemen binnen een werkdag contact met u op. Voor dringende vragen kunt u ons ook telefonisch bereiken.</p>

          <form class="space-y-6" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-ink mb-2">Voornaam *</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  class="w-full px-4 py-3 border border-border-default rounded-none text-ink placeholder-ink-subtle focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none bg-white"
                  placeholder="Jan"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-ink mb-2">Achternaam *</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  class="w-full px-4 py-3 border border-border-default rounded-none text-ink placeholder-ink-subtle focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none bg-white"
                  placeholder="de Vries"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-ink mb-2">E-mailadres *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 border border-border-default rounded-none text-ink placeholder-ink-subtle focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none bg-white"
                  placeholder="jan@bedrijf.nl"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-ink mb-2">Telefoonnummer</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 border border-border-default rounded-none text-ink placeholder-ink-subtle focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none bg-white"
                  placeholder="06-12345678"
                />
              </div>
            </div>

            <div>
              <label for="serviceType" class="block text-sm font-medium text-ink mb-2">Interesse in</label>
              <select
                id="serviceType"
                name="serviceType"
                class="w-full px-4 py-3 border border-border-default rounded-none text-ink focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none appearance-none bg-white"
              >
                <option value="">Selecteer een dienst</option>
                <option value="afvalhout">Afvalhout</option>
                <option value="banden">Banden</option>
                <option value="bedrijfsafval">Bedrijfsafval</option>
                <option value="papier">Papier</option>
                <option value="collectief">Deelname aan het collectief</option>
                <option value="overig">Overig</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-ink mb-2">Bericht *</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-border-default rounded-none text-ink placeholder-ink-subtle focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors outline-none resize-vertical bg-white"
                placeholder="Vertel ons hoe wij u kunnen helpen &mdash; informatie over het collectief, vrijblijvend advies over schaalvoordelen, of een andere vraag..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-dark transition-colors"
            >
              Verstuur Bericht
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-1">
          <div class="bg-white border border-border-default p-8 sticky top-24">
            <h3 class="text-lg font-bold text-ink mb-6" style="font-family: var(--font-heading);">Andere manieren om ons te bereiken</h3>

            <div class="space-y-6">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink mb-1">Telefoon</div>
                  <a href="tel:+31411611470" class="text-primary font-medium hover:text-primary-dark transition-colors">+31(0)411-611470</a>
                  <p class="text-ink-subtle text-sm mt-1">Ma - Vr: 8:00 - 17:00</p>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink mb-1">E-mail</div>
                  <a href="mailto:Info@WasteConnection.nl" class="text-primary font-medium hover:text-primary-dark transition-colors">Info@WasteConnection.nl</a>
                  <p class="text-ink-subtle text-sm mt-1">Reactie binnen 1 werkdag</p>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink mb-1">Adres</div>
                  <p class="text-ink-muted text-sm">Nieuwe Bredase Baan 30<br/>4825 BP Breda</p>
                </div>
              </div>
            </div>

            <!-- Divider -->
            <div class="border-t border-border-default my-8"></div>

            <!-- Collectief info -->
            <div>
              <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">Deelnemen aan het collectief?</h3>
              <p class="text-ink-muted text-sm mb-4">
                Wilt u profiteren van de schaalvoordelen van WasteConnection? Neem vrijblijvend contact met ons op en wij vertellen u graag meer over de mogelijkheden voor uw bedrijf.
              </p>
              <a
                href="/over-ons"
                class="inline-flex items-center gap-2 text-primary font-semibold text-sm hover:text-primary-dark transition-colors"
              >
                Meer over het collectief
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="border-2 border-dashed border-border-default h-80 flex items-center justify-center bg-surface-dim">
        <div class="text-center">
          <svg class="w-16 h-16 text-ink-subtle/30 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <p class="text-ink-subtle font-medium text-lg">Nieuwe Bredase Baan 30, Breda</p>
          <p class="text-ink-subtle/70 text-sm mt-1">4825 BP Breda &mdash; Hetzelfde adres als Ecopark Breda</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
