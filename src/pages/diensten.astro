---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const afvalhoutDetails = [
  {
    title: 'Partnerschap met RWE',
    description: 'Al sinds begin 2000 werken wij samen met de RWE biomassacentrale in Duitsland. Deze langlopende samenwerking garandeert een stabiele en betrouwbare afzet voor sloop- en afvalhout. Een groeiend aantal recyclingbedrijven sluit zich aan als partner om te profiteren van deze unieke positie.',
  },
  {
    title: 'Volledige Ontzorging',
    description: 'Wij verzorgen het complete traject: exportvergunningen, kwaliteitsborging en financiele afwikkeling. Door de ontzorging hoeft het recyclingbedrijf zich alleen nog maar bezig te houden met hun kerntaken en klanten. Geen administratieve rompslomp, wel maximale focus op uw core business.',
  },
  {
    title: 'Verwerking per Kwaliteit',
    description: 'Sloop- en afvalhout wordt verwerkt op basis van kwaliteit. De beste kwaliteit gaat naar spaanplaatproductie, verontreinigd hout wordt ingezet als secundaire brandstof, en alle overige kwaliteiten worden verwerkt tot biomassa en brandstof. Zo wordt elke houtfractie optimaal benut.',
  },
];

const bandenDetails = [
  {
    title: 'Ook Kleine Hoeveelheden',
    description: 'In tegenstelling tot de meeste verwerkers die enorme volumes eisen, accepteren wij ook kleine hoeveelheden banden. Door de volumes van het collectief te bundelen profiteren ook kleinere bedrijven van scherpe tarieven. Wij ontzorgen u eenvoudig met bandenverwerking.',
  },
  {
    title: 'Geen Sortering Nodig',
    description: 'Autobanden, vrachtwagenbanden, tractorbanden &mdash; met of zonder velgen. Alles mag gemengd worden aangeleverd. Geen sortering nodig, geen gedoe. U levert aan en wij regelen de rest. Profiteer van de schaalvoordelen van ons collectief.',
  },
  {
    title: 'Hoogwaardige Eindproducten',
    description: 'Banden worden verwerkt tot rubbertegels, diverse laagwaardige producten en secundaire brandstof voor cementovens. Elke band krijgt een verantwoorde bestemming. Door collectieve verwerking realiseren wij betere tarieven dan bij individuele afvoer mogelijk is.',
  },
];

const bedrijfsafvalDetails = [
  {
    title: 'Meer dan 10 Jaar Ervaring',
    description: 'Al meer dan 10 jaar verzorgen wij de afvoer van bedrijfsafval, KWD en reststromen voor een groot aantal recyclingbedrijven. Door deze jarenlange ervaring en ons uitgebreide netwerk ontzorgen wij u volledig bij de verwerking van al uw bedrijfsafvalstromen.',
  },
  {
    title: 'R1-status en Energieterugwinning',
    description: 'Nederlandse AVIs (afvalverwerkingsinstallaties) beschikken over de R1-status, wat staat voor superieure energieterugwinning. Wij hebben langetermijncontracten van 1 tot 17 jaar met grote energieproducenten als Essent en RWE. Deelname versterkt bovendien de duurzaamheidspositionering van uw bedrijf.',
  },
  {
    title: 'Duurzaamheidsvoordeel',
    description: 'Door deel te nemen aan het collectief van WasteConnection profiteert uw bedrijf van een sterkere duurzaamheidspositionering. De gegarandeerde R1-verwerking en langetermijncontracten maken het mogelijk om uw milieuprestaties aantoonbaar te verbeteren en uit te dragen.',
  },
];

const papierDetails = [
  {
    title: 'Partnerschap met Smurfit Kappa',
    description: 'Wij werken samen met Smurfit Kappa Recycling voor de afzet van oud papier. De experts van Smurfit Kappa beschikken over specifieke kennis per papiersoort, waardoor u altijd marktconforme afzetprijzen ontvangt. Deze samenwerking combineert onze ontzorging met hun papierexpertise.',
  },
  {
    title: 'Administratie en Transport',
    description: 'WasteConnection neemt de volledige administratieve last en transportplanning over. U hoeft zich niet bezig te houden met facturatie, inzamelschema&rsquo;s of logistieke afstemming. Wij bundelen de inzameling en zorgen voor een efficient en kosteneffectief traject van bron tot verwerker.',
  },
  {
    title: 'Milieu Service Brabant',
    description: 'Onze zusteronderneming Milieu Service Brabant nam in 2013 de papierinzameling in Eindhoven over van Smurfit Kappa. Deze overname versterkte ons netwerk en onze expertise in papierrecycling. Samen bieden wij gebundelde inzameling en marktconforme afzet voor al uw papierstromen.',
  },
];
---

<Layout title="Diensten" description="WasteConnection biedt collectieve verwerking van afvalhout, banden, bedrijfsafval en papier. Ontdek de schaalvoordelen van ons collectief van 40+ bedrijven in Breda.">
  <Hero
    title="Collectieve afvalverwerking voor uw bedrijf"
    subtitle="WasteConnection ontzorgt recyclingbedrijven bij de verwerking van vier afvalstromen. Van sloophout voor de RWE biomassacentrale tot papier met Smurfit Kappa &mdash; profiteer van de schaalvoordelen van ons collectief."
    compact
  />

  <!-- Afvalhout -->
  <section id="afvalhout" class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Dienst 01</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Afvalhout
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Al sinds begin 2000 werken wij samen met de RWE biomassacentrale in Duitsland voor de verwerking van sloop- en afvalhout. Wij verzorgen exportvergunningen, kwaliteitsborging en financiele afwikkeling &mdash; volledige ontzorging zodat u zich kunt richten op uw kerntaken.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {afvalhoutDetails.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < afvalhoutDetails.length - 1 ? 'lg:border-r border-border-default' : '',
            i < afvalhoutDetails.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visual break -->
  <div class="relative w-full h-64 lg:h-80 overflow-hidden">
    <img src="/images/recycling.jpg" alt="" aria-hidden="true" loading="lazy" width="1400" height="800" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/75"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <p class="text-white text-2xl lg:text-3xl font-extrabold tracking-tight text-center px-4" style="font-family: var(--font-heading);">Ontzorging door schaalvoordelen &mdash; dat is de kracht van het collectief</p>
    </div>
  </div>

  <!-- Banden -->
  <section id="banden" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Dienst 02</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Banden
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Wij ontzorgen u eenvoudig met bandenverwerking. Ook kleine hoeveelheden zijn welkom, sorteren is niet nodig. Autobanden, vrachtwagenbanden en tractorbanden &mdash; met of zonder velgen &mdash; mogen gemengd worden aangeleverd. Profiteer van de schaalvoordelen van ons collectief.
        </p>
      </div>
      <!-- Numbered vertical list for banden -->
      <div class="space-y-0">
        {bandenDetails.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === bandenDetails.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bedrijfsafval -->
  <section id="bedrijfsafval" class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Dienst 03</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Bedrijfsafval
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Al meer dan 10 jaar verzorgen wij de afvoer van bedrijfsafval, KWD en reststromen voor een groot aantal recyclingbedrijven. Nederlandse AVIs beschikken over de R1-status voor superieure energieterugwinning. Langetermijncontracten met Essent en RWE bieden zekerheid.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {bedrijfsafvalDetails.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < bedrijfsafvalDetails.length - 1 ? 'lg:border-r border-border-default' : '',
            i < bedrijfsafvalDetails.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Papier -->
  <section id="papier" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Dienst 04</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Papier
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          In samenwerking met Smurfit Kappa Recycling bieden wij marktconforme afzet en gebundelde inzameling van oud papier. De experts van Smurfit Kappa beschikken over specifieke kennis per papiersoort. Wij nemen de administratieve last en transportplanning volledig over.
        </p>
      </div>
      <div class="space-y-0">
        {papierDetails.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === papierDetails.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
