---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    number: '01',
    title: 'Afvalhout',
    description: 'Collectieve verwerking van afvalhout op basis van partnerschap. Wij nemen het volledige administratieve traject uit handen en zorgen voor een betrouwbare, duurzame verwerking van uw afvalhoutstromen. Door de gebundelde volumes van ons collectief realiseren wij scherpe tarieven die individueel onhaalbaar zijn.',
  },
  {
    number: '02',
    title: 'Banden',
    description: 'Gezamenlijke inzameling en recycling van banden tegen gunstige voorwaarden. Door de vraag van 40+ bedrijven te bundelen, onderhandelen wij scherpe collectieve tarieven bij gecertificeerde verwerkers. U levert eenvoudig aan en wij regelen de rest &mdash; van logistiek tot verantwoorde verwerking.',
  },
  {
    number: '03',
    title: 'Bedrijfsafval',
    description: 'Collectieve inkoop voor bedrijfsafvalverwerking met aantoonbare kosten- en duurzaamheidsvoordelen. Wij matchen vraag en aanbod tussen deelnemers, optimaliseren de logistiek en zorgen voor transparante verwerking. Zo bespaart u op kosten en draagt u bij aan een circulaire economie.',
  },
  {
    number: '04',
    title: 'Papier',
    description: 'Stabiele partnerschappen voor papierrecycling met financiele voordelen voor elke deelnemer. Door langetermijncontracten met betrouwbare verwerkers garanderen wij prijsstabiliteit en continuiteit. Uw oud papier wordt verantwoord verwerkt en krijgt een tweede leven.',
  },
];
---

<Layout title="Home">
  <Hero
    title="Het collectief dat u sterker maakt"
    subtitle="WasteConnection is het afvalcollectief in Breda dat 40+ bedrijven ontzorgt op het gebied van afvalverwerking. Door collectieve inkoop, slimme uitruillogistiek en transparante processen realiseren wij schaalvoordelen die individueel onbereikbaar zijn."
    ctaText="Neem Contact Op"
    ctaHref="/contact"
    secondaryCtaText="Bekijk Diensten"
    secondaryCtaHref="/diensten"
  />

  <!-- Services Overview — Numbered vertical list -->
  <section class="py-16 lg:py-24 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <span class="label">Onze Diensten</span>
        <h2 class="mt-3 text-h2 font-extrabold text-ink">
          Vier afvalstromen, een collectief
        </h2>
        <p class="mt-4 text-lg text-ink-muted">
          WasteConnection bundelt de krachten van 40+ bedrijven voor de collectieve verwerking van vier belangrijke afvalstromen. Door slim vraag en aanbod te matchen realiseren wij schaalvoordelen en ontzorgen wij uw bedrijf volledig.
        </p>
      </div>

      <!-- Numbered service list -->
      <div class="space-y-0">
        {services.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === services.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            {/* Number — always left on desktop */}
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">{service.number}</span>
            </div>
            {/* Title */}
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            {/* Description */}
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <a
          href="/diensten"
          class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-dark transition-colors"
        >
          Alle Diensten Bekijken
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Stats />

  <!-- Why Choose Us -->
  <section class="py-24 lg:py-36 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Waarom WasteConnection</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Uw afvalpartner in collectieve kracht sinds 2005
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            Sinds 2005 helpt WasteConnection bedrijven in de regio Breda om samen sterker te staan in afvalverwerking. Wat begon als een lokaal initiatief is uitgegroeid tot een collectief van meer dan 40 bedrijven die gezamenlijk profiteren van schaalvoordelen, transparante processen en duurzame verwerking.
          </p>
          <ul class="space-y-5">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Collectieve Inkoopkracht</span>
                <p class="text-ink-muted text-sm mt-1">Door de volumes van 40+ bedrijven te bundelen onderhandelen wij tarieven die u als individueel bedrijf nooit zou kunnen bereiken. Meer volume betekent meer onderhandelingskracht en lagere kosten per ton.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Slim Uitruilen</span>
                <p class="text-ink-muted text-sm mt-1">Ons uitruil-principe optimaliseert vraag en aanbod tussen deelnemers. Door logistieke stromen slim te combineren verlagen wij transportkosten en minimaliseren wij de ecologische voetafdruk.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Langetermijncontracten</span>
                <p class="text-ink-muted text-sm mt-1">Met contracten van 1 tot 17 jaar bij grote energieproducenten zoals Essent en RWE bieden wij prijsstabiliteit en zekerheid. Geen verrassingen, wel continuiteit.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Volledige Transparantie</span>
                <p class="text-ink-muted text-sm mt-1">Transparantie in afvalverwerking is onze fundamentele missie. U weet precies waar uw afval naartoe gaat, hoe het verwerkt wordt en welke kosten daarbij horen. Wij zijn een prima vraagbaak voor al uw afvalvragen.</p>
              </div>
            </li>
          </ul>
        </div>
        <!-- Key figures — stacked editorial, no cards -->
        <div class="relative space-y-8 lg:pt-4">
          <!-- Community image behind stats -->
          <img src="/images/community.jpg" alt="Collectieve kracht van samenwerking" loading="lazy" width="800" height="600" class="rounded-sm w-full h-48 object-cover mb-8" />
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">20+</span>
            <p class="label mt-1">Jaar Ervaring</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">40+</span>
            <p class="label mt-1">Deelnemende Bedrijven</p>
          </div>
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">4</span>
            <p class="label mt-1">Afvalstromen</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">NIWO</span>
            <p class="label mt-1">Gecertificeerd Collectief</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA variant="contact" />
</Layout>
