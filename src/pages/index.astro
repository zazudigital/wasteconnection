---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    number: '01',
    title: 'Residential Collection',
    description: 'Scheduled weekly curbside garbage and recycling for single-family homes, townhomes, and HOA communities. We provide durable carts, stick to a consistent pickup window, and offer the WasteConnect app so you always know when your truck is coming.',
  },
  {
    number: '02',
    title: 'Commercial Waste',
    description: 'Right-sized collection programs for restaurants, retailers, offices, and industrial facilities. Front-load, rear-load, and compactor service with flexible schedules from one to seven days a week, tailored to your waste volume and operational hours.',
  },
  {
    number: '03',
    title: 'Recycling Programs',
    description: 'Single-stream and source-separated recycling for homes and businesses. We process paper, cardboard, plastics #1-7, glass, and metals at our own MRFs, diverting millions of tons from landfills annually.',
  },
  {
    number: '04',
    title: 'Roll-Off Dumpsters',
    description: 'Open-top roll-off containers in 10, 20, 30, and 40 cubic yard sizes for construction sites, renovations, estate cleanouts, and roofing projects. Same-day delivery available in most markets with flexible rental periods.',
  },
  {
    number: '05',
    title: 'Bulk & Yard Waste',
    description: 'Curbside yard debris collection during growing season plus on-demand bulk pickup for furniture, appliances, and mattresses. Schedule online or through the WasteConnect app and we handle the heavy lifting.',
  },
  {
    number: '06',
    title: 'Special & E-Waste',
    description: 'Permitted collection and disposal of non-hazardous special waste, contaminated soils, industrial by-products, and electronic equipment. Fully compliant with EPA, state, and provincial regulations so you never have to worry about liability.',
  },
];
---

<Layout title="Home">
  <Hero
    title="Keeping North America Clean, One Community at a Time"
    subtitle="From the curb to the landfill and everything in between, Waste Connections delivers the collection, recycling, and disposal services that 8 million households and businesses across 43 states and 6 Canadian provinces count on every week."
    ctaText="Get a Free Quote"
    ctaHref="/contact"
    secondaryCtaText="See All Services"
    secondaryCtaHref="/services"
  />

  <!-- Services Overview — Numbered vertical list -->
  <section class="py-16 lg:py-24 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <span class="label">What We Do</span>
        <h2 class="mt-3 text-h2 font-extrabold text-ink">
          Full-Spectrum Waste & Recycling Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted">
          Residential carts, commercial dumpsters, construction roll-offs, recycling, organics, and special waste &mdash; all managed under one provider with local teams who know your community.
        </p>
      </div>

      <!-- Numbered service list -->
      <div class="space-y-0">
        {services.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === services.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            {/* Number — always left on desktop */}
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">{service.number}</span>
            </div>
            {/* Title */}
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            {/* Description */}
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <a
          href="/services"
          class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-dark transition-colors"
        >
          View All Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Stats />

  <!-- Why Choose Us -->
  <section class="py-24 lg:py-36 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Why Waste Connections</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Built on 27 Years of Showing Up, Rain or Shine
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            Since 1997, Waste Connections has grown from a regional hauler into one of North America's largest integrated waste services companies. Our 21,000+ team members operate a fleet of collection vehicles, transfer stations, recycling facilities, and engineered landfills &mdash; all held to the highest safety and environmental standards in the industry.
          </p>
          <ul class="space-y-5">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Safety-First Culture</span>
                <p class="text-ink-muted text-sm mt-1">Every driver, technician, and operator starts the day with a safety briefing. Our industry-leading training programs and vehicle technology keep employees and neighborhoods safe.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Measurable Sustainability</span>
                <p class="text-ink-muted text-sm mt-1">We operate recycling facilities, landfill gas-to-energy plants, and a growing CNG fleet &mdash; actively diverting millions of tons from landfills and converting methane into renewable electricity.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Deep Community Roots</span>
                <p class="text-ink-muted text-sm mt-1">We hire locally, sponsor youth sports leagues, partner with schools on recycling education, and invest in the long-term health of every market we serve.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">On-Time, Every Time</span>
                <p class="text-ink-muted text-sm mt-1">GPS-tracked trucks, optimized routes, and local dispatchers mean consistent pickup windows. If something goes wrong, our customer service team resolves it the same day.</p>
              </div>
            </li>
          </ul>
        </div>
        <!-- Key figures — stacked editorial, no cards -->
        <div class="space-y-8 lg:pt-4">
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">27+</span>
            <p class="label mt-1">Years Protecting Communities</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">100+</span>
            <p class="label mt-1">Operating Markets</p>
          </div>
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">8M+</span>
            <p class="label mt-1">Customers Served Weekly</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">21K+</span>
            <p class="label mt-1">Dedicated Employees</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA variant="app" />

  <CTA variant="contact" />
</Layout>
