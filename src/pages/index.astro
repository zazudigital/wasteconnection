---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    number: '01',
    title: 'Afvalhout',
    description: 'Al sinds begin 2000 werken wij samen met de RWE biomassacentrale in Duitsland voor de verwerking van sloop- en afvalhout. Wij verzorgen exportvergunningen, kwaliteitsborging en financiele afwikkeling. De beste kwaliteit hout gaat naar spaanplaatproductie, verontreinigd hout wordt ingezet als secundaire brandstof, en alle overige kwaliteiten worden verwerkt tot biomassa. Door onze ontzorging houdt het recyclingbedrijf zich alleen nog bezig met kerntaken en klanten.',
  },
  {
    number: '02',
    title: 'Banden',
    description: 'Wij ontzorgen u eenvoudig met bandenverwerking. Ook kleine hoeveelheden zijn welkom &mdash; in tegenstelling tot de meeste verwerkers die enorme volumes eisen. Sorteren is niet nodig: autobanden, vrachtwagenbanden en tractorbanden, met of zonder velgen, mogen gemengd worden aangeleverd. Eindproducten zijn onder andere rubbertegels, laagwaardige producten en secundaire brandstof voor cementovens. Profiteer van de schaalvoordelen van ons collectief.',
  },
  {
    number: '03',
    title: 'Bedrijfsafval',
    description: 'Al meer dan 10 jaar verzorgen wij de afvoer van bedrijfsafval, KWD en reststromen voor een groot aantal recyclingbedrijven. Nederlandse AVIs (afvalverwerkingsinstallaties) beschikken over de R1-status, wat staat voor superieure energieterugwinning. Wij hebben langetermijncontracten van 1 tot 17 jaar met grote energieproducenten als Essent en RWE. Deelname biedt uw bedrijf bovendien een sterkere duurzaamheidspositionering.',
  },
  {
    number: '04',
    title: 'Papier',
    description: 'In samenwerking met Smurfit Kappa Recycling bieden wij marktconforme afzet en gebundelde inzameling van oud papier. De experts van Smurfit Kappa beschikken over de specifieke kennis per papiersoort. Wij nemen de administratieve last en transportplanning over, zodat u zich kunt richten op uw kernactiviteiten. Onze zusteronderneming Milieu Service Brabant nam in 2013 de papierinzameling in Eindhoven over van Smurfit Kappa.',
  },
];
---

<Layout title="Home">
  <Hero
    title="Het collectief dat u sterker maakt"
    subtitle="WasteConnection is het afvalcollectief dat recyclingbedrijven volledig ontzorgt. Door collectieve inkoop, langetermijncontracten met grote energieproducenten en gebundelde volumes realiseren wij schaalvoordelen die individueel onbereikbaar zijn. Zo houdt u zich alleen bezig met uw kerntaken en klanten."
    ctaText="Neem Contact Op"
    ctaHref="/contact"
    secondaryCtaText="Bekijk Diensten"
    secondaryCtaHref="/diensten"
  />

  <!-- Services Overview — Numbered vertical list -->
  <section class="py-16 lg:py-24 bg-surface-bright" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <span class="label">Onze Diensten</span>
        <h2 class="mt-3 text-h2 font-extrabold text-ink">
          Vier afvalstromen, een collectief
        </h2>
        <p class="mt-4 text-lg text-ink-muted">
          WasteConnection bundelt de krachten van recyclingbedrijven voor de collectieve verwerking van vier afvalstromen. Van sloophout voor de RWE biomassacentrale tot papierinzameling met Smurfit Kappa &mdash; wij ontzorgen u volledig en bieden schaalvoordelen door gebundelde volumes.
        </p>
      </div>

      <!-- Numbered service list -->
      <div class="space-y-0">
        {services.map((service, i) => (
          <div class:list={[
            'service-row grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 px-4 -mx-4 rounded-sm border-t border-border-default',
            i === services.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            {/* Number — always left on desktop */}
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/30 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">{service.number}</span>
            </div>
            {/* Title */}
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            {/* Description */}
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <a
          href="/diensten"
          class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-dark transition-colors"
        >
          Alle Diensten Bekijken
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Stats />

  <!-- Why Choose Us -->
  <section class="py-24 lg:py-36 bg-white" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Waarom WasteConnection</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Ontzorging door collectieve kracht sinds begin 2000
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            Sinds begin 2000 ontzorgt WasteConnection recyclingbedrijven en andere ondernemingen op het gebied van afvalverwerking. Wat begon met een partnerschap met de RWE biomassacentrale in Duitsland is uitgegroeid tot een collectief dat vier afvalstromen beheert. Een groeiend aantal recyclingbedrijven sluit zich aan als partner om te profiteren van onze schaalvoordelen, langetermijncontracten en volledige ontzorging.
          </p>
          <ul class="space-y-5">
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Collectieve Inkoopkracht</span>
                <p class="text-ink-muted text-sm mt-1">Door de volumes van een groot aantal recyclingbedrijven te bundelen onderhandelen wij tarieven die individueel onbereikbaar zijn. Van afvalhout voor biomassacentrales tot banden voor cementovens &mdash; schaalvoordelen op elke stroom.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Volledige Ontzorging</span>
                <p class="text-ink-muted text-sm mt-1">Wij nemen het complete traject uit handen: exportvergunningen, kwaliteitsborging, transportplanning, administratie en financiele afwikkeling. Door de ontzorging hoeft u zich alleen nog bezig te houden met uw kerntaken en klanten.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Langetermijncontracten</span>
                <p class="text-ink-muted text-sm mt-1">Met contracten van 1 tot 17 jaar bij grote energieproducenten als Essent en RWE bieden wij prijsstabiliteit en zekerheid. Nederlandse AVIs beschikken over R1-status voor superieure energieterugwinning.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 border-2 border-primary flex items-center justify-center mt-0.5 shrink-0">
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </div>
              <div>
                <span class="font-bold text-ink">Sterke Partnerschappen</span>
                <p class="text-ink-muted text-sm mt-1">Samen met partners als RWE, Essent en Smurfit Kappa Recycling garanderen wij betrouwbare verwerking. Onze zusteronderneming Milieu Service Brabant versterkt het netwerk met expertise in inzameling en logistiek.</p>
              </div>
            </li>
          </ul>
        </div>
        <!-- Key figures — stacked editorial, no cards -->
        <div class="relative space-y-8 lg:pt-4">
          <!-- Collectief afbeelding -->
          <img src="/images/community.jpg" alt="Collectieve kracht van samenwerking" loading="lazy" width="800" height="600" class="rounded-sm w-full h-48 object-cover mb-8" />
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">20+</span>
            <p class="label mt-1">Jaar Ervaring</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">40+</span>
            <p class="label mt-1">Deelnemende Bedrijven</p>
          </div>
          <div class="border-l-4 border-primary pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">4</span>
            <p class="label mt-1">Afvalstromen</p>
          </div>
          <div class="border-l-4 border-accent pl-6">
            <span class="text-5xl lg:text-6xl font-extrabold text-primary tracking-tight tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">NIWO</span>
            <p class="label mt-1">Gecertificeerd Collectief</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA variant="contact" />
</Layout>
