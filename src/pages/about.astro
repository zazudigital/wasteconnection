---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import CTA from '../components/CTA.astro';

const values = [
  {
    title: 'Safety Above All Else',
    description: 'Every morning, every route, every facility starts with safety. We invest in collision-avoidance technology, on-board cameras, continuous driver training, and rigorous pre-trip inspections. Our goal is zero incidents &mdash; because every employee deserves to go home to their family at the end of every shift.',
  },
  {
    title: 'Environmental Stewardship',
    description: 'We do not just collect waste &mdash; we manage its entire lifecycle responsibly. From single-stream recycling and organics composting to landfill gas-to-energy conversion and a growing fleet of CNG-powered trucks, every operational decision is weighed against its environmental impact.',
  },
  {
    title: 'Rooted in Our Communities',
    description: 'We hire locally, sponsor neighborhood cleanups, fund school recycling education programs, and support first responders and veterans in the markets we serve. When a community trusts us with an essential service, we earn that trust by being genuinely invested in its well-being.',
  },
  {
    title: 'Integrity in Every Interaction',
    description: 'Honest pricing, transparent billing, ethical business practices. We treat customers, employees, and municipal partners with the same respect we expect in return. When we make a commitment &mdash; a pickup day, a service level, a price &mdash; we stand behind it.',
  },
];

const timeline = [
  { year: '1997', event: 'Waste Connections incorporated in The Woodlands, Texas, with a strategy focused on exclusive and secondary markets where the company could deliver superior service and build lasting municipal partnerships.' },
  { year: '2000s', event: 'Aggressive yet disciplined growth through over 100 strategic acquisitions, expanding from a regional Texas hauler to a coast-to-coast operator with collection, transfer, and disposal assets across dozens of US states.' },
  { year: '2016', event: 'Transformative merger with Progressive Waste Solutions, adding major Canadian operations and creating one of the three largest solid waste companies in North America with combined revenues exceeding $4 billion.' },
  { year: '2020s', event: 'Accelerated investment in sustainability infrastructure &mdash; landfill gas-to-energy projects, CNG fleet expansion, materials recovery facilities &mdash; alongside the launch of the WasteConnect app to modernize the customer experience.' },
  { year: 'Today', event: 'Over 21,000 employees serving 8+ million customers across 43 US states and 6 Canadian provinces, operating an integrated network of collection routes, transfer stations, recycling facilities, and engineered landfills.' },
];
---

<Layout title="About Us" description="Waste Connections has grown from a 1997 Texas startup into one of North America's largest integrated waste services companies, with 21,000+ employees serving 8M+ customers across 43 states and 6 Canadian provinces.">
  <Hero
    title="From a Regional Hauler to a North American Leader"
    subtitle="Founded in 1997 with a focus on underserved markets, Waste Connections has spent 27 years earning the trust of communities across the continent &mdash; one reliable pickup, one honest interaction, and one environmental commitment at a time."
    compact
  />

  <!-- Mission Section -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Our Mission</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Essential Services, Responsibly Delivered
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Waste Connections is the third-largest solid waste services company in North America, providing collection, transfer, disposal, and recycling services to more than 8 million residential, commercial, and industrial customers. We operate an integrated infrastructure of collection routes, transfer stations, material recovery facilities, and engineered landfills.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Our mission is straightforward: deliver safe, reliable, and environmentally responsible waste management while being a genuine partner to the communities and municipalities that depend on us. We measure success not just in tonnage moved, but in safety records maintained, landfill diversion rates improved, and neighborhoods kept clean.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed">
            Headquartered in The Woodlands, Texas, we employ over 21,000 people and operate in 43 US states and 6 Canadian provinces &mdash; with a deliberate focus on exclusive and secondary markets where we can deliver consistently superior service.
          </p>
        </div>
        <div class="relative">
          <div class="overflow-hidden border-l-4 border-primary" style="background: linear-gradient(135deg, #006F51 0%, #1E3A5F 100%);">
            <div class="p-10 lg:p-14">
              <blockquote class="text-white text-xl lg:text-2xl font-medium leading-relaxed mb-6" style="font-family: Georgia, 'Times New Roman', serif;">
                &ldquo;We built this company on a simple idea: if you take care of your people, serve your communities with integrity, and invest in the environment, long-term success follows naturally.&rdquo;
              </blockquote>
              <div class="flex items-center gap-3">
                <div class="w-1 h-12 bg-accent"></div>
                <div>
                  <div class="text-white font-semibold">Waste Connections</div>
                  <div class="text-white/70 text-sm">Executive Leadership</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">What Drives Us</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          The Principles Behind Every Pickup
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-2xl mx-auto">
          These are not words on a wall. They are operating standards that shape how our 21,000+ employees make decisions every day &mdash; from the route driver planning the safest path to the account manager designing a customer's recycling program.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-border-default">
        {values.map((value, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < 2 ? 'border-b border-border-default' : '',
            i % 2 === 0 ? 'md:border-r border-border-default' : '',
          ]}>
            <span class="text-3xl font-extrabold text-primary/15 block mb-3" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">{value.title}</h3>
            <p class="text-ink-muted leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Stats />

  <!-- Timeline -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">Our Journey</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          27 Years of Disciplined Growth
        </h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-4 top-0 bottom-0 w-px bg-border-default"></div>

          <div class="space-y-10">
            {timeline.map((item) => (
              <div class="relative flex items-start gap-6 pl-0">
                <div class="relative z-10 w-8 h-8 bg-primary flex items-center justify-center shrink-0">
                  <div class="w-2 h-2 bg-white"></div>
                </div>
                <div class="pt-0.5">
                  <div class="text-primary font-bold text-lg mb-1" style="font-family: var(--font-heading);">{item.year}</div>
                  <p class="text-ink-muted leading-relaxed">{item.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sustainability -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Environmental Stewardship</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Sustainability Is an Operating Standard, Not a Slogan
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            We own the infrastructure, which means we control the outcomes. Every landfill we operate is engineered with gas collection systems; every recycling facility we run diverts tonnage from disposal; and our growing CNG fleet displaces thousands of gallons of diesel every year. Sustainability at Waste Connections is measured in real metrics, reported transparently.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 border border-border-default">
            <div class="p-6 border-b border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Materials Recovery</div>
              <p class="text-ink-muted text-sm">Our MRFs process millions of tons of recyclables each year, sorting paper, plastics, glass, and metals back into the manufacturing supply chain.</p>
            </div>
            <div class="p-6 border-b border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Landfill Gas-to-Energy</div>
              <p class="text-ink-muted text-sm">We capture methane from decomposing waste at our landfills and convert it into renewable electricity and pipeline-quality natural gas.</p>
            </div>
            <div class="p-6 border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">CNG-Powered Fleet</div>
              <p class="text-ink-muted text-sm">Hundreds of compressed natural gas collection trucks on the road today, cutting greenhouse gas emissions by up to 25% compared to diesel.</p>
            </div>
            <div class="p-6">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Community Education</div>
              <p class="text-ink-muted text-sm">Hands-on school programs, municipal recycling workshops, and public facility tours that teach residents how to waste less and recycle right.</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="border border-border-default p-8 lg:p-12 text-center bg-surface-dim">
            <div class="w-24 h-24 bg-primary/10 flex items-center justify-center mx-auto mb-6">
              <svg class="w-12 h-12 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">Closing the Loop on Waste</h3>
            <p class="text-ink-muted leading-relaxed max-w-md mx-auto">
              Our vertically integrated model &mdash; collection, transfer, processing, and disposal &mdash; means we can track materials from the curb to their final destination and continuously find new ways to recover value and reduce what goes to landfill.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
