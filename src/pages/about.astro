---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import CTA from '../components/CTA.astro';

const values = [
  {
    title: 'Safety Is Our #1 Value',
    description: 'Every morning, every route, every facility starts with safety. It is not just a priority &mdash; it is our #1 value, full stop. We invest in collision-avoidance technology, driver training, and rigorous inspections because every team member deserves to go home to their family at the end of every shift.',
  },
  {
    title: 'Champions of a Greener Tomorrow',
    description: 'We do not just collect waste &mdash; we champion a greener and cleaner tomorrow. From single-stream recycling and organics composting to landfill gas-to-energy conversion and our growing CNG fleet, every decision is weighed against its impact on the communities we serve.',
  },
  {
    title: 'Rooted in Your Community',
    description: 'We hire locally, sponsor neighborhood cleanups, fund school recycling education programs, and support first responders and veterans. When your community trusts us to show up every week, we earn that trust by being genuinely invested in your neighborhood&rsquo;s well-being.',
  },
  {
    title: 'Honest Service, Real Savings',
    description: 'Fair pricing, transparent billing, and no surprises on your statement. We treat every customer like a neighbor. When we make a commitment &mdash; a pickup day, a service level, a price &mdash; we stand behind it. That is why customers stay with us for 5, 6, even 10+ years.',
  },
];

const timeline = [
  { year: '1997', event: 'Waste Connections started in The Woodlands, Texas, with a simple goal: serve communities that deserved better waste service and build lasting relationships with the neighborhoods that trusted us.' },
  { year: '2000s', event: 'Steady growth through over 100 acquisitions, expanding from a Texas-based team to a coast-to-coast provider &mdash; always keeping our focus on the communities we serve and the people who make it happen.' },
  { year: '2016', event: 'Joined forces with Progressive Waste Solutions, welcoming Canadian communities into the Waste Connections family and becoming one of the leading full-service solid waste providers in North America.' },
  { year: '2020s', event: 'Big investments in a greener tomorrow &mdash; landfill gas-to-energy, CNG fleet expansion, and recycling facilities &mdash; plus the launch of the WasteConnect app so customers never miss a collection day.' },
  { year: 'Today', event: 'Over 21,000 friendly team members serving 8+ million customers across 43 US states and 6 Canadian provinces. Still family-focused, still community-driven, still helping you say goodbye to waste worries.' },
];
---

<Layout title="About Us" description="Waste Connections has been your neighborhood's waste partner since 1997 — one of the leading full-service solid waste collection providers in North America, with 21,000+ friendly team members serving 8M+ customers across 43 states and 6 Canadian provinces.">
  <Hero
    title="Your Neighborhood's Waste Partner Since 1997"
    subtitle="For over 27 years, Waste Connections has been earning the trust of communities across North America &mdash; one friendly pickup, one honest conversation, and one commitment to a greener tomorrow at a time."
    compact
  />

  <!-- Mission Section -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Our Mission</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Helping Communities Say Goodbye to Waste Worries
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Waste Connections is one of the leading full-service solid waste collection providers in North America, providing collection, transfer, disposal, and recycling services to more than 8 million residential, commercial, and industrial customers. We are not just a waste company &mdash; we are your neighbors.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Our mission is simple: deliver safe, reliable waste management while being a genuine partner to the communities that depend on us. Safety is our #1 value, and we measure success by the neighborhoods we keep clean, the savings we deliver to customers, and the greener and cleaner tomorrow we are building together.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed">
            Headquartered in The Woodlands, Texas, our 21,000+ friendly team members serve communities across 43 US states and 6 Canadian provinces &mdash; with a focus on the markets where we can make the biggest difference.
          </p>
        </div>
        <div class="relative">
          <img src="/images/recycling.jpg" alt="Recycling programs keeping materials out of landfills" loading="lazy" class="w-full h-56 object-cover rounded-sm mb-6" />
          <div class="overflow-hidden border-l-4 border-primary" style="background: linear-gradient(135deg, #006F51 0%, #1E3A5F 100%);">
            <div class="p-10 lg:p-14">
              <blockquote class="text-white text-xl lg:text-2xl font-medium leading-relaxed mb-6" style="font-family: Georgia, 'Times New Roman', serif;">
                &ldquo;We built this company on a simple idea: take care of your people, serve your communities like good neighbors, and champion a greener tomorrow. The rest takes care of itself.&rdquo;
              </blockquote>
              <div class="flex items-center gap-3">
                <div class="w-1 h-12 bg-accent"></div>
                <div>
                  <div class="text-white font-semibold">Waste Connections</div>
                  <div class="text-white/70 text-sm">Executive Leadership</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">What Drives Us</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          The Values Behind Every Pickup
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-2xl mx-auto">
          These are not words on a wall. They are the commitments our 21,000+ team members live by every day &mdash; from the driver who waves hello on your street to the account manager who knows your name and your needs.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-border-default">
        {values.map((value, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < 2 ? 'border-b border-border-default' : '',
            i % 2 === 0 ? 'md:border-r border-border-default' : '',
          ]}>
            <span class="text-3xl font-extrabold text-primary/15 block mb-3" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">{value.title}</h3>
            <p class="text-ink-muted leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Stats />

  <!-- Timeline -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="label">Our Journey</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          27 Years of Growing With Our Communities
        </h2>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-4 top-0 bottom-0 w-px bg-border-default"></div>

          <div class="space-y-10">
            {timeline.map((item) => (
              <div class="relative flex items-start gap-6 pl-0">
                <div class="relative z-10 w-8 h-8 bg-primary flex items-center justify-center shrink-0">
                  <div class="w-2 h-2 bg-white"></div>
                </div>
                <div class="pt-0.5">
                  <div class="text-primary font-bold text-lg mb-1" style="font-family: var(--font-heading);">{item.year}</div>
                  <p class="text-ink-muted leading-relaxed">{item.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sustainability -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="label">Our Green Commitment</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink mb-6" style="font-family: var(--font-heading);">
            Building a Greener and Cleaner Tomorrow
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-8">
            We champion a greener tomorrow because it is the right thing to do &mdash; and because it saves you money. Every landfill we operate captures gas for clean energy. Every recycling facility diverts valuable materials from disposal. Our growing CNG fleet cuts emissions while keeping your service reliable. Real results, not just promises.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 border border-border-default">
            <div class="p-6 border-b border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Materials Recovery</div>
              <p class="text-ink-muted text-sm">Our facilities process millions of tons of recyclables each year, keeping paper, plastics, glass, and metals out of landfills and back where they belong.</p>
            </div>
            <div class="p-6 border-b border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Landfill Gas-to-Energy</div>
              <p class="text-ink-muted text-sm">We capture methane from decomposing waste at our landfills and convert it into renewable electricity and pipeline-quality natural gas.</p>
            </div>
            <div class="p-6 border-r border-border-default">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">CNG-Powered Fleet</div>
              <p class="text-ink-muted text-sm">Hundreds of compressed natural gas trucks on the road, cutting greenhouse gas emissions by up to 25% compared to diesel &mdash; cleaner air for your neighborhood.</p>
            </div>
            <div class="p-6">
              <div class="text-lg font-bold text-primary mb-1" style="font-family: var(--font-heading);">Community Education</div>
              <p class="text-ink-muted text-sm">Hands-on school programs, neighborhood recycling workshops, and facility tours that help your community waste less and recycle smarter.</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/images/sustainability.jpg" alt="Sustainable practices and green initiatives" loading="lazy" class="w-full h-64 object-cover mb-6 rounded-sm" />
          <div class="border border-border-default p-8 lg:p-12 text-center bg-surface-dim">
            <div class="w-24 h-24 bg-primary/10 flex items-center justify-center mx-auto mb-6">
              <svg class="w-12 h-12 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-ink mb-3" style="font-family: var(--font-heading);">From Your Curb to a Cleaner Future</h3>
            <p class="text-ink-muted leading-relaxed max-w-md mx-auto">
              Because we handle everything from collection to processing and disposal, we can track materials from your curb to their final destination &mdash; always finding new ways to recover value, reduce waste, and save you money along the way.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
