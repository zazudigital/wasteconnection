---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const residentialServices = [
  {
    title: 'Curbside Garbage Collection',
    description: 'Weekly automated pickup on a set schedule you can count on. We supply durable 64- or 96-gallon carts, and our GPS-tracked trucks follow optimized routes so your waste is collected during the same window every week.',
  },
  {
    title: 'Single-Stream Recycling',
    description: 'Toss all accepted recyclables &mdash; paper, cardboard, plastics #1-7, glass, aluminum, and tin &mdash; into one cart. Our materials recovery facilities sort and process everything, keeping valuable resources out of landfills and back in the supply chain.',
  },
  {
    title: 'Bulk Item Pickup',
    description: 'Couches, mattresses, water heaters, old appliances &mdash; items too large for your regular cart. Schedule a bulk pickup through the WasteConnect app or by phone, and our crew will collect them right from the curb on a date that works for you.',
  },
  {
    title: 'Yard Waste & Organics',
    description: 'Seasonal curbside collection of leaves, branches, grass clippings, and garden debris. Available weekly from spring through fall in most markets, with composting at our organics processing facilities to return nutrients to the soil.',
  },
  {
    title: 'Residential Roll-Off Dumpsters',
    description: 'Tackling a kitchen renovation, roof replacement, or whole-house cleanout? Rent a 10- or 20-yard roll-off container delivered to your driveway. Flexible rental periods with prompt pickup when you are finished.',
  },
  {
    title: 'E-Waste & Electronics Recycling',
    description: 'Safe, certified disposal of computers, monitors, TVs, printers, and mobile devices. We partner with R2-certified processors to recover precious metals and prevent hazardous materials like lead and mercury from entering the waste stream.',
  },
];

const commercialServices = [
  {
    title: 'Scheduled Waste Collection',
    description: 'Front-load, rear-load, and automated collection from 2- to 8-yard containers on a one-to-seven-day schedule built around your operations. Ideal for restaurants, office parks, retail centers, and multi-tenant properties that need consistent, hassle-free service.',
  },
  {
    title: 'Construction & Demolition Roll-Offs',
    description: 'Open-top containers in 10, 20, 30, and 40 cubic yard sizes for job sites, warehouse cleanouts, and large-scale commercial projects. Same-day delivery and swap-out available in most markets to keep your project on schedule.',
  },
  {
    title: 'Compactors & Waste Reduction',
    description: 'Self-contained and stationary compactors that crush waste volume by up to 80%, dramatically reducing haul frequency and annual disposal costs. We handle installation, maintenance, and monitoring so your team can focus on core business.',
  },
  {
    title: 'Commercial Recycling Programs',
    description: 'We start with a comprehensive waste audit of your facility, then design a custom recycling program &mdash; from source-separated cardboard and plastics to single-stream options &mdash; that maximizes your diversion rate and can qualify your business for sustainability certifications.',
  },
  {
    title: 'Organic & Food Waste Diversion',
    description: 'Purpose-built collection for restaurants, grocery chains, food processors, and institutional kitchens. Pre- and post-consumer food waste is transported to composting or anaerobic digestion facilities, turning organic waste into soil amendments and renewable energy.',
  },
];

const specializedServices = [
  {
    title: 'Portable Restroom Services',
    description: 'ADA-compliant standard and deluxe portable restrooms, hand-wash stations, and high-capacity restroom trailers for construction sites, festivals, sporting events, and emergency response. All units are serviced on a regular schedule to maintain hygiene and appearance.',
  },
  {
    title: 'Special & Regulated Waste',
    description: 'Permitted collection, transportation, and disposal of non-hazardous special waste &mdash; including contaminated soils, industrial sludge, asbestos-containing materials, and petroleum-impacted debris. Full manifesting, chain-of-custody documentation, and regulatory compliance so your project stays on the right side of EPA and state agencies.',
  },
  {
    title: 'Landfills & Transfer Stations',
    description: 'We own and operate engineered Subtitle D landfills and regional transfer stations equipped with leachate management, continuous groundwater monitoring, and landfill gas collection systems that convert methane into renewable energy &mdash; turning long-term waste management into a net environmental benefit.',
  },
];
---

<Layout title="Services" description="Residential garbage and recycling, commercial waste collection, roll-off dumpsters, compactors, organics diversion, special waste, and portable restrooms from Waste Connections. Serving 8M+ customers across the US and Canada.">
  <Hero
    title="Every Service You Need, From One Trusted Provider"
    subtitle="Residential curbside pickup, commercial dumpsters, construction roll-offs, recycling, organics processing, special waste disposal, and portable sanitation &mdash; all backed by 21,000+ employees and 27 years of operational excellence."
    compact
  />

  <!-- Residential Services -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">For Your Home</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Residential Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Dependable weekly collection, easy single-stream recycling, and on-demand bulk and yard waste pickup &mdash; all designed to keep your household running smoothly and your neighborhood looking its best. We serve over 6 million homes across 43 states and 6 Canadian provinces.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0 border border-border-default">
        {residentialServices.map((service, i) => (
          <div class:list={[
            'p-8 group hover:bg-white transition-colors',
            i < 3 ? 'border-b border-border-default' : '',
            (i % 3 !== 2) ? 'lg:border-r border-border-default' : '',
            (i % 2 !== 1) ? 'sm:border-r border-border-default lg:border-r-0' : '',
            (i % 3 !== 2) ? '' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commercial Services -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">For Your Business</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Commercial & Industrial Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Whether you operate a single storefront or manage dozens of facilities, we build a waste management plan around your volume, your hours, and your budget. Our account managers conduct on-site assessments to right-size your containers and optimize pickup frequency &mdash; so you only pay for what you actually need.
        </p>
      </div>
      <!-- Numbered vertical list for commercial services -->
      <div class="space-y-0">
        {commercialServices.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === commercialServices.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialized Services -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Beyond Collection</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Specialized & Infrastructure Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Waste management does not end at the curb. We own and operate the transfer stations, landfills, and processing facilities that responsibly handle materials after pickup &mdash; and provide portable sanitation and special waste services for projects and events of every scale.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {specializedServices.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < specializedServices.length - 1 ? 'lg:border-r border-border-default' : '',
            i < specializedServices.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
