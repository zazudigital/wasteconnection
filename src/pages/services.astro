---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';

const residentialServices = [
  {
    title: 'Curbside Garbage Collection',
    description: 'Depend on Waste Connections for prompt, efficient trash services right at your home. We supply durable carts and our trucks follow optimized routes so you get timely pickup during the same window every week. Never miss your collection day.',
  },
  {
    title: 'Single-Stream Recycling',
    description: 'Waste Connections champions a greener tomorrow! Toss all accepted recyclables &mdash; paper, cardboard, plastics, glass, aluminum, and tin &mdash; into one cart. We sort and process everything, keeping valuable resources out of landfills and helping build a cleaner community.',
  },
  {
    title: 'Bulk Item Pickup',
    description: 'Couches, mattresses, water heaters, old appliances &mdash; items too large for your regular cart? No problem! Schedule a bulk pickup through the WasteConnect app or by phone, and our crew will collect them right from the curb on a date that works for you.',
  },
  {
    title: 'Yard Waste & Organics',
    description: 'Leaves, branches, grass clippings, garden debris &mdash; we take it all off your hands. Available weekly from spring through fall in most markets, with composting at our organics facilities to return nutrients to the soil and help build a greener and cleaner tomorrow.',
  },
  {
    title: 'Residential Roll-Off Dumpsters',
    description: 'Tackling a kitchen renovation, roof replacement, or whole-house cleanout? Rent a 10- or 20-yard roll-off container delivered right to your driveway. Flexible rental periods, fair pricing, and prompt pickup when you are finished &mdash; easy as that.',
  },
  {
    title: 'E-Waste & Electronics Recycling',
    description: 'Not sure what to do with old computers, monitors, TVs, or phones? We make it simple. Safe, certified disposal through R2-certified processors that recover precious metals and keep hazardous materials out of the waste stream.',
  },
];

const commercialServices = [
  {
    title: 'Scheduled Waste Collection',
    description: 'A range of dumpster sizes and scheduling service options designed to meet your specific waste collection needs. Front-load, rear-load, and automated collection on a schedule built around your hours &mdash; ideal for restaurants, office parks, retail centers, and multi-tenant properties.',
  },
  {
    title: 'Construction & Demolition Roll-Offs',
    description: 'Open-top containers in 10, 20, 30, and 40 cubic yard sizes for job sites, warehouse cleanouts, and large-scale commercial projects. Same-day delivery and swap-out in most markets &mdash; so your project stays on schedule and on budget.',
  },
  {
    title: 'Compactors & Waste Reduction',
    description: 'By compacting your waste, you can effectively reduce pickup frequency and significantly save on expenses. Our self-contained and stationary compactors crush waste volume by up to 80%. We handle installation, maintenance, and monitoring so your team can focus on what matters most.',
  },
  {
    title: 'Commercial Recycling Programs',
    description: 'We champion a greener tomorrow for your business, too. We start with a waste audit of your facility, then design a custom recycling program &mdash; from source-separated cardboard and plastics to single-stream options &mdash; that saves you money and helps the planet.',
  },
  {
    title: 'Organic & Food Waste Diversion',
    description: 'Purpose-built collection for restaurants, grocery chains, food processors, and institutional kitchens. We turn your food waste into soil amendments and renewable energy &mdash; reducing your disposal costs while helping build a greener and cleaner tomorrow.',
  },
];

const specializedServices = [
  {
    title: 'Portable Restroom Services',
    description: 'ADA-compliant standard and deluxe portable restrooms, hand-wash stations, and restroom trailers for construction sites, festivals, sporting events, and more. All units are serviced on a regular schedule so you can focus on your event or project, not logistics.',
  },
  {
    title: 'Special & Regulated Waste',
    description: 'Not sure how to handle contaminated soils, industrial sludge, or other regulated materials? We take the complexity off your plate. Fully permitted collection, transportation, and disposal with complete documentation and regulatory compliance &mdash; one less thing for you to worry about.',
  },
  {
    title: 'Landfills & Transfer Stations',
    description: 'We own and operate engineered landfills and regional transfer stations with leachate management, groundwater monitoring, and gas collection systems that convert methane into renewable energy. Because a greener and cleaner tomorrow starts with how we manage waste today.',
  },
];
---

<Layout title="Services" description="Home and business waste management services and dumpster rentals from Waste Connections. Residential garbage, recycling, commercial waste, compactors, and more — say goodbye to waste and hello to savings!">
  <Hero
    title="Home and Business Waste Management Made Easy"
    subtitle="From curbside pickup to commercial dumpsters and construction roll-offs &mdash; everything you need from one friendly, reliable provider. Say goodbye to waste and hello to savings!"
    compact
  />

  <!-- Residential Services -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">For Your Home</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Residential Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Depend on Waste Connections for prompt and efficient trash services right at your home. Timely trash pickup, easy single-stream recycling, and on-demand bulk and yard waste collection &mdash; all designed to keep your household running smoothly and your neighborhood looking its best.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0 border border-border-default">
        {residentialServices.map((service, i) => (
          <div class:list={[
            'p-8 group hover:bg-white transition-colors',
            i < 3 ? 'border-b border-border-default' : '',
            (i % 3 !== 2) ? 'lg:border-r border-border-default' : '',
            (i % 2 !== 1) ? 'sm:border-r border-border-default lg:border-r-0' : '',
            (i % 3 !== 2) ? '' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visual break — recycling image -->
  <div class="relative w-full h-64 lg:h-80 overflow-hidden">
    <img src="/images/recycling.jpg" alt="" aria-hidden="true" loading="lazy" width="1400" height="800" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/75"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <p class="text-white text-2xl lg:text-3xl font-extrabold tracking-tight text-center px-4" style="font-family: var(--font-heading);">Champions of a Greener Tomorrow</p>
    </div>
  </div>

  <!-- Commercial Services -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">For Your Business</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Commercial & Industrial Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Whether you run a single storefront or manage dozens of facilities, we build a waste management plan around your volume, your hours, and your budget. Your dedicated account manager will work with you to find the right-sized solution &mdash; so you save money and only pay for what you actually need.
        </p>
      </div>
      <!-- Numbered vertical list for commercial services -->
      <div class="space-y-0">
        {commercialServices.map((service, i) => (
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 border-t border-border-default',
            i === commercialServices.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/20 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialized Services -->
  <section class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label">Beyond Collection</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          Specialized & Infrastructure Services
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          Waste management does not end at the curb. We own and operate the transfer stations, landfills, and processing facilities that responsibly handle materials after pickup &mdash; and provide portable sanitation and special waste services for projects and events of every size.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {specializedServices.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < specializedServices.length - 1 ? 'lg:border-r border-border-default' : '',
            i < specializedServices.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/15 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
