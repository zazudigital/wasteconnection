---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import { useTranslations, localePath, type Locale } from '../i18n';

const locale = (Astro.currentLocale || 'nl') as Locale;
const t = useTranslations(locale);

const afvalhoutDetails = t('diensten.afvalhout.details') as Array<{ title: string; description: string }>;
const bandenDetails = t('diensten.banden.details') as Array<{ title: string; description: string }>;
const bedrijfsafvalDetails = t('diensten.bedrijfsafval.details') as Array<{ title: string; description: string }>;
const papierDetails = t('diensten.papier.details') as Array<{ title: string; description: string }>;
---

<Layout title={t('diensten.meta.title')} description={t('diensten.meta.description')}>
  <Hero
    title={t('diensten.hero.title')}
    subtitle={t('diensten.hero.subtitle')}
    compact
  />

  <!-- Afvalhout -->
  <section id="afvalhout" class="py-20 lg:py-28 bg-surface-bright" data-animate>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label text-primary">{t('diensten.afvalhout.label')}</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          {t('diensten.afvalhout.heading')}
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          {t('diensten.afvalhout.intro')}
        </p>
      </div>
      <img src="/images/afvalhout.jpg" alt="Afvalhout verwerking" loading="lazy" width="1400" height="600" class="w-full h-56 lg:h-72 object-cover rounded-sm mb-10" />
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {afvalhoutDetails.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < afvalhoutDetails.length - 1 ? 'lg:border-r border-border-default' : '',
            i < afvalhoutDetails.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/25 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visual break -->
  <div class="relative w-full h-64 lg:h-80 overflow-hidden">
    <img src="/images/hero-facility.jpg" alt="" aria-hidden="true" loading="lazy" width="1400" height="800" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/75"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <p class="text-white text-2xl lg:text-3xl font-extrabold tracking-tight text-center px-4" style="font-family: var(--font-heading);">{t('diensten.visualBreak')}</p>
    </div>
  </div>

  <!-- Banden -->
  <section id="banden" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label text-primary">{t('diensten.banden.label')}</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          {t('diensten.banden.heading')}
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          {t('diensten.banden.intro')}
        </p>
      </div>
      <img src="/images/banden.jpg" alt="Bandenverwerking" loading="lazy" width="1400" height="600" class="w-full h-56 lg:h-72 object-cover rounded-sm mb-10" />
      <!-- Numbered vertical list for banden -->
      <div class="space-y-0">
        {bandenDetails.map((service, i) => (
          <div class:list={[
            'service-row grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 px-4 -mx-4 rounded-sm border-t border-border-default',
            i === bandenDetails.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/30 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bedrijfsafval -->
  <section id="bedrijfsafval" class="py-20 lg:py-28 bg-surface-bright">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label text-primary">{t('diensten.bedrijfsafval.label')}</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          {t('diensten.bedrijfsafval.heading')}
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          {t('diensten.bedrijfsafval.intro')}
        </p>
      </div>
      <img src="/images/hero-facility.jpg" alt="Bedrijfsafval verwerking" loading="lazy" width="1400" height="600" class="w-full h-56 lg:h-72 object-cover rounded-sm mb-10" />
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-border-default">
        {bedrijfsafvalDetails.map((service, i) => (
          <div class:list={[
            'p-8 lg:p-10',
            i < bedrijfsafvalDetails.length - 1 ? 'lg:border-r border-border-default' : '',
            i < bedrijfsafvalDetails.length - 1 ? 'border-b lg:border-b-0 border-border-default' : '',
          ]}>
            <span class="text-2xl font-extrabold text-primary/25 block mb-2" style="font-family: var(--font-heading);">0{i + 1}</span>
            <h3 class="text-lg font-bold text-ink mb-3" style="font-family: var(--font-heading);">{service.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Papier -->
  <section id="papier" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14">
        <span class="label text-primary">{t('diensten.papier.label')}</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold text-ink" style="font-family: var(--font-heading);">
          {t('diensten.papier.heading')}
        </h2>
        <p class="mt-4 text-lg text-ink-muted max-w-3xl">
          {t('diensten.papier.intro')}
        </p>
      </div>
      <img src="/images/papier.jpg" alt="Papier recycling" loading="lazy" width="1400" height="600" class="w-full h-56 lg:h-72 object-cover rounded-sm mb-10" />
      <div class="space-y-0">
        {papierDetails.map((service, i) => (
          <div class:list={[
            'service-row grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-8 py-8 lg:py-10 px-4 -mx-4 rounded-sm border-t border-border-default',
            i === papierDetails.length - 1 ? 'border-b border-border-default' : '',
          ]}>
            <div class="lg:col-span-1">
              <span class="text-3xl lg:text-4xl font-extrabold text-primary/30 tabular-nums" style="font-family: var(--font-heading); font-variant-numeric: tabular-nums;">0{i + 1}</span>
            </div>
            <div class="lg:col-span-3 flex items-start">
              <h3 class="text-lg lg:text-xl font-bold text-ink" style="font-family: var(--font-heading);">{service.title}</h3>
            </div>
            <div class="lg:col-span-8">
              <p class="text-ink-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA variant="contact" />
</Layout>
